# Database (PostgreSQL) - Railway provides this automatically
DATABASE_URL=postgresql://user:password@host:port/dbname

# LLM API - Use OpenRouter (recommended, supports gemini-2.5-flash)
# Sign up at https://openrouter.ai/ and get an API key
OPENROUTER_API_KEY=sk-or-xxxxx

# Image Detection APIs
# SightEngine - Sign up at https://sightengine.com/ (free tier: 500 ops/month)
SIGHTENGINE_API_USER=your_user_id
SIGHTENGINE_API_SECRET=your_secret

# Illuminarty - Sign up at https://illuminarty.ai/ (optional)
ILLUMINARTY_API_KEY=your_key

# Server
NODE_ENV=production
PORT=3000

# CORS - Set to your frontend URL
CORS_ORIGIN=https://fakeguard.org
